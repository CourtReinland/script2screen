#!/bin/bash
# ============================================================================
# ScriptToScreen post-install script
# Runs AFTER the pkg installs files to /Library/ and ~/Library/
#
# This script handles everything that can't be done by file-copy alone:
#   - Homebrew detection/install
#   - Python 3.10+ detection/install
#   - ffmpeg detection/install
#   - Virtual environment creation
#   - pip dependency installation
#   - MLX-Audio setup (Apple Silicon only)
#
# This runs as root (invoked by the macOS Installer), but user-space
# operations (venvs, pip) are run via `sudo -u $USER_NAME` so files
# are owned by the user, not root.
# ============================================================================

set -euo pipefail

# The macOS Installer sets these environment variables:
# $USER = the installing user's short name
# $HOME = the installing user's home directory
# But when running as root, $HOME is /var/root, so we derive it:
USER_NAME="${USER:-$(stat -f '%Su' /dev/console)}"
USER_HOME="$(dscl . -read "/Users/$USER_NAME" NFSHomeDirectory 2>/dev/null | awk '{print $2}')" || USER_HOME="/Users/$USER_NAME"

LOG_DIR="$USER_HOME/Library/Logs/ScriptToScreen"
LOG_FILE="$LOG_DIR/install.log"
USER_PKG_DIR="$USER_HOME/Library/Application Support/ScriptToScreen"

MIN_PYTHON_MAJOR=3
MIN_PYTHON_MINOR=10

# ============================================================================
# Logging
# ============================================================================

sudo -u "$USER_NAME" mkdir -p "$LOG_DIR"
exec > >(tee -a "$LOG_FILE") 2>&1

log() {
    echo "[$(date '+%Y-%m-%d %H:%M:%S')] $*"
}

log "========================================="
log "ScriptToScreen Post-Install"
log "User: $USER_NAME  Home: $USER_HOME"
log "========================================="

# Helper: run a command as the installing user (not root)
run_as_user() {
    sudo -u "$USER_NAME" "$@"
}

# ============================================================================
# Fix permissions on installed files
# ============================================================================

log "[1/6] Fixing file permissions..."

# The pkg installs to ~/Library/Application Support/ScriptToScreen/
# Make sure it's owned by the user, not root
if [ -d "$USER_PKG_DIR/script_to_screen" ]; then
    chown -R "$USER_NAME":staff "$USER_PKG_DIR/script_to_screen" 2>/dev/null || true
    chmod -R 755 "$USER_PKG_DIR/script_to_screen"
    log "  Python package permissions fixed"
fi

# Also ensure the user pkg dir itself is user-owned
chown "$USER_NAME":staff "$USER_PKG_DIR" 2>/dev/null || true

# Ensure Resolve script files are readable
RESOLVE_UTILITY="/Library/Application Support/Blackmagic Design/DaVinci Resolve/Fusion/Scripts/Utility"
RESOLVE_EDIT="/Library/Application Support/Blackmagic Design/DaVinci Resolve/Fusion/Scripts/Edit"
chmod -R 755 "$RESOLVE_UTILITY/ScriptToScreen.lua" 2>/dev/null || true
chmod -R 755 "$RESOLVE_EDIT"/STS_*.lua 2>/dev/null || true

# ============================================================================
# Detect/install Homebrew
# ============================================================================

log "[2/6] Checking Homebrew..."

BREW=""
for candidate in "/opt/homebrew/bin/brew" "/usr/local/bin/brew"; do
    if [ -f "$candidate" ] && [ -x "$candidate" ]; then
        BREW="$candidate"
        break
    fi
done

# Also check user's PATH
if [ -z "$BREW" ]; then
    BREW_FROM_PATH=$(run_as_user bash -lc "command -v brew" 2>/dev/null || true)
    if [ -n "$BREW_FROM_PATH" ] && [ -f "$BREW_FROM_PATH" ]; then
        BREW="$BREW_FROM_PATH"
    fi
fi

if [ -z "$BREW" ]; then
    log "  Homebrew not found. Installing..."
    # Homebrew's installer must run as the user, not root
    run_as_user /bin/bash -c "$(curl -fsSL https://raw.githubusercontent.com/Homebrew/install/HEAD/install.sh)" </dev/null 2>&1 || {
        log "  WARNING: Homebrew installation failed. Python/ffmpeg may need manual install."
        log "  You can install Homebrew later: https://brew.sh"
    }
    # Re-detect
    for candidate in "/opt/homebrew/bin/brew" "/usr/local/bin/brew"; do
        if [ -f "$candidate" ] && [ -x "$candidate" ]; then
            BREW="$candidate"
            break
        fi
    done
fi

if [ -n "$BREW" ]; then
    log "  Homebrew: $BREW"
else
    log "  WARNING: Homebrew not available. Continuing with system Python..."
fi

# ============================================================================
# Detect/install Python 3.10+
# ============================================================================

log "[3/6] Checking Python..."

PYTHON=""

# Check brew Pythons first (most reliable)
if [ -n "$BREW" ]; then
    BREW_PREFIX="$($BREW --prefix 2>/dev/null || echo "/opt/homebrew")"
    for pyver in 3.14 3.13 3.12 3.11 3.10; do
        candidate="$BREW_PREFIX/opt/python@$pyver/bin/python3"
        if [ -f "$candidate" ]; then
            PYTHON="$candidate"
            log "  Found brew Python $pyver: $PYTHON"
            break
        fi
    done
fi

# Check system Python
if [ -z "$PYTHON" ]; then
    for candidate in python3.14 python3.13 python3.12 python3.11 python3.10 python3; do
        FOUND=$(run_as_user bash -lc "command -v $candidate" 2>/dev/null || true)
        if [ -n "$FOUND" ] && [ -f "$FOUND" ]; then
            ver=$("$FOUND" -c "import sys; print(f'{sys.version_info.major}.{sys.version_info.minor}')" 2>/dev/null || echo "0.0")
            major=$(echo "$ver" | cut -d. -f1)
            minor=$(echo "$ver" | cut -d. -f2)
            if [ "$major" -ge "$MIN_PYTHON_MAJOR" ] 2>/dev/null && [ "$minor" -ge "$MIN_PYTHON_MINOR" ] 2>/dev/null; then
                PYTHON="$FOUND"
                log "  Found system Python $ver: $PYTHON"
                break
            fi
        fi
    done
fi

# Install Python if needed
if [ -z "$PYTHON" ] && [ -n "$BREW" ]; then
    log "  Python >= $MIN_PYTHON_MAJOR.$MIN_PYTHON_MINOR not found. Installing via Homebrew..."
    run_as_user "$BREW" install python@3.12 2>&1 | tail -5 || {
        log "  WARNING: Python installation failed"
    }
    BREW_PREFIX="$($BREW --prefix 2>/dev/null || echo "/opt/homebrew")"
    PYTHON="$BREW_PREFIX/opt/python@3.12/bin/python3"
fi

if [ -z "$PYTHON" ] || [ ! -f "$PYTHON" ]; then
    log "  ERROR: No suitable Python found. Venv creation will be skipped."
    log "  Please install Python 3.10+ manually and re-run the installer."
else
    log "  Python: $PYTHON ($($PYTHON --version 2>&1))"
fi

# ============================================================================
# Install ffmpeg
# ============================================================================

log "[4/6] Checking ffmpeg..."

FFMPEG=""
for candidate in "/opt/homebrew/bin/ffmpeg" "/usr/local/bin/ffmpeg"; do
    if [ -f "$candidate" ] && [ -x "$candidate" ]; then
        FFMPEG="$candidate"
        break
    fi
done

if [ -z "$FFMPEG" ] && [ -n "$BREW" ]; then
    log "  ffmpeg not found. Installing via Homebrew..."
    run_as_user "$BREW" install ffmpeg 2>&1 | tail -3 || {
        log "  WARNING: ffmpeg install failed. Audio merging may not work."
    }
fi

# ============================================================================
# Create Python virtual environment and install dependencies
# ============================================================================

log "[5/6] Setting up Python virtual environment..."

if [ -n "$PYTHON" ] && [ -f "$PYTHON" ]; then
    VENV_DIR="$USER_PKG_DIR/venv"

    if [ ! -f "$VENV_DIR/bin/python3" ]; then
        run_as_user "$PYTHON" -m venv "$VENV_DIR" 2>&1 || {
            log "  WARNING: venv creation failed"
        }
    fi

    if [ -f "$VENV_DIR/bin/pip" ]; then
        log "  Installing Python packages..."
        run_as_user "$VENV_DIR/bin/pip" install --upgrade pip setuptools wheel 2>&1 | tail -2 || true
        run_as_user "$VENV_DIR/bin/pip" install \
            "pdfplumber>=0.10.0" \
            "requests>=2.31.0" \
            "Pillow>=10.0.0" \
            PyJWT \
            gradio_client \
            huggingface_hub 2>&1 | tail -5 || {
            log "  WARNING: Some Python packages failed to install"
        }
        log "  Python packages installed"
    fi

    # Verify
    if run_as_user "$VENV_DIR/bin/python3" -c "import pdfplumber, requests, PIL; print('OK')" 2>/dev/null; then
        log "  Venv verification: OK"
    else
        log "  WARNING: Venv verification failed — some packages may be missing"
    fi
else
    log "  Skipping venv setup (no Python available)"
fi

# ============================================================================
# MLX-Audio setup (Apple Silicon only)
# ============================================================================

log "[6/6] Setting up MLX-Audio..."

ARCH="$(uname -m)"
if [ "$ARCH" = "arm64" ] && [ -n "$PYTHON" ] && [ -f "$PYTHON" ]; then
    MLX_VENV="$USER_PKG_DIR/mlx-venv"

    if [ ! -f "$MLX_VENV/bin/python3" ]; then
        run_as_user "$PYTHON" -m venv "$MLX_VENV" 2>&1 || {
            log "  WARNING: MLX venv creation failed"
        }
    fi

    if [ -f "$MLX_VENV/bin/pip" ]; then
        run_as_user "$MLX_VENV/bin/pip" install --upgrade pip setuptools wheel 2>&1 | tail -1 || true
        run_as_user "$MLX_VENV/bin/pip" install mlx mlx-audio 2>&1 | tail -5 || {
            log "  WARNING: MLX-Audio install failed. Local TTS will not be available."
        }
        log "  MLX-Audio setup complete"
    fi
else
    if [ "$ARCH" != "arm64" ]; then
        log "  Skipping MLX-Audio (requires Apple Silicon, detected: $ARCH)"
    else
        log "  Skipping MLX-Audio (no Python available)"
    fi
fi

# ============================================================================
# Create user config directory
# ============================================================================

run_as_user mkdir -p "$USER_HOME/.config/script_to_screen" 2>/dev/null || true

# ============================================================================
# Final verification summary
# ============================================================================

log ""
log "========================================="
log "Installation Summary"
log "========================================="

ERRORS=0

check_file() {
    local path="$1"
    local label="$2"
    if [ -f "$path" ]; then
        log "  [OK] $label"
    else
        log "  [FAIL] $label — $path"
        ERRORS=$((ERRORS + 1))
    fi
}

check_file "$RESOLVE_UTILITY/ScriptToScreen.lua" "Main wizard"
check_file "$RESOLVE_EDIT/STS_Common.lua" "STS_Common.lua"
check_file "$RESOLVE_EDIT/STS_Toolbar.lua" "STS_Toolbar.lua"
check_file "$RESOLVE_EDIT/STS_Lip_Sync.lua" "STS_Lip_Sync.lua"
check_file "$RESOLVE_EDIT/STS_Generate_Audio.lua" "STS_Generate_Audio.lua"
check_file "$RESOLVE_EDIT/STS_ReframeShot.lua" "STS_ReframeShot.lua"
check_file "$RESOLVE_EDIT/STS_Reprompt_Image.lua" "STS_Reprompt_Image.lua"
check_file "$RESOLVE_EDIT/STS_Reprompt_Video.lua" "STS_Reprompt_Video.lua"
check_file "$RESOLVE_EDIT/STS_ScriptRef.lua" "STS_ScriptRef.lua"
check_file "$RESOLVE_EDIT/STS_ExpandShots.lua" "STS_ExpandShots.lua"
check_file "$USER_PKG_DIR/script_to_screen/__init__.py" "Python package"

if [ -f "$USER_PKG_DIR/venv/bin/python3" ]; then
    log "  [OK] Python venv"
else
    log "  [WARN] Python venv not created (may need manual setup)"
fi

log ""
if [ "$ERRORS" -eq 0 ]; then
    log "Installation complete! Restart DaVinci Resolve."
else
    log "Installation completed with $ERRORS missing file(s). Check log: $LOG_FILE"
fi

exit 0
